{% extends 'base.html.twig' %}

{% block title %}Nouveau Emprunt{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h2 class="h5 mb-0">➕ Enregistrer un nouvel emprunt</h2>
            </div>
            <div class="card-body">
                {{ form_start(form) }}
                    {{ form_widget(form) }}
                    <button class="btn btn-success mt-3 fw-bold">Enregistrer</button>
                {{ form_end(form) }}
            </div>
            <div class="card-footer">
                <a href="{{ path('app_emprunt_index') }}" class="btn btn-outline-secondary btn-sm">← Retour à la liste</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}