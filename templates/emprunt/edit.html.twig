{% extends 'base.html.twig' %}

{% block title %}Modifier l'emprunt{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-warning text-dark">
                <h2 class="h5 mb-0">✏️ Modifier l'emprunt #{{ emprunt.id }}</h2>
            </div>
            <div class="card-body">
                {{ form_start(form) }}
                    {{ form_widget(form) }}
                    <button class="btn btn-success mt-3 fw-bold">Mettre à jour</button>
                {{ form_end(form) }}
            </div>
            <div class="card-footer d-flex justify-content-between">
                <a href="{{ path('app_emprunt_index') }}" class="btn btn-outline-secondary btn-sm">← Retour à la liste</a>
                <form method="post" action="{{ path('app_emprunt_delete', {'id': emprunt.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet emprunt ?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ emprunt.id) }}">
                    <button class="btn btn-danger btn-sm">Supprimer</button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
