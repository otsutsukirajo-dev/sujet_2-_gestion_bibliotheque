{% extends 'base.html.twig' %}

{% block title %}Connexion - BiblioTech{% endblock %}

{% block body %}
<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-header bg-dark text-white text-center py-3">
                <h3 class="h5 mb-0 fw-bold">🔑 Connexion Administration</h3>
            </div>
            <div class="card-body p-4">
                
                {% if error %}
                    <div class="alert alert-danger shadow-sm mb-3">
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                {% if app.user %}
                    <div class="alert alert-info mb-3">
                        Vous êtes déjà connecté en tant que <strong>{{ app.user.userIdentifier }}</strong>. 
                        <a href="{{ path('app_logout') }}" class="alert-link">Se déconnecter</a>
                    </div>
                {% else %}
                    <form method="post" action="{{ path('app_login') }}">
                        <div class="mb-3">
                            <label for="username" class="form-label font-weight-semibold">Adresse Email</label>
                            <input type="email" value="{{ last_username }}" name="_username" id="username" class="form-control" autocomplete="email" required autofocus placeholder="admin@bibliotech.com">
                        </div>

                        <div class="mb-4">
                            <label for="password" class="form-label font-weight-semibold">Mot de passe</label>
                            <input type="password" name="_password" id="password" class="form-control" autocomplete="current-password" required placeholder="••••••••">
                        </div>

                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                        <button class="btn btn-primary w-100 py-2 fw-semibold" type="submit">
                            Se connecter
                        </button>
                    </form>

                    <div class="text-center mt-3">
                        <span class="text-muted">Pas encore de compte ?</span>
                        <a href="{{ path('app_register') }}" class="fw-semibold">Créer un compte</a>
                    </div>
                {% endif %}

            </div>
        </div>
    </div>
</div>
{% endblock %}