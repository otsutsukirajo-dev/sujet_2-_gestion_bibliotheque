{% extends 'base.html.twig' %}

{% block title %}Nouveau Livre{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h2 class="h5 mb-0">➕ Ajouter un nouveau livre</h2>
            </div>
            <div class="card-body">
                {{ include('livre/_form.html.twig') }}
            </div>
            <div class="card-footer">
                <a href="{{ path('app_livre_index') }}" class="btn btn-outline-secondary btn-sm">← Retour au catalogue</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}